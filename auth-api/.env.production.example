# ============================================================
# .env.production.example  —  生产环境变量模板
#
# 使用方式：
#   cp .env.production.example .env
#   填写所有 REQUIRED 字段后再启动服务
#
# 安全须知：
#   - 绝不将 .env 文件提交到 Git
#   - 所有密钥请使用密码生成器生成（推荐 openssl rand -hex 64）
#   - 生产数据库/Redis 不要使用默认密码
# ============================================================

# ─── 服务器 ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── 数据库（PostgreSQL） ── REQUIRED ───────────────────────
# DATABASE_URL 与下方分项配置二选一，推荐使用 DATABASE_URL
DATABASE_URL=postgresql://YOURUSER:YOURPASSWORD@postgres:5432/auth_database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=auth_database
DB_USER=YOURUSER
# REQUIRED：必须设置强密码，禁止使用 'password'
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# 可选：数据库 SSL（云数据库通常需要开启）
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# ─── JWT 密钥 ── REQUIRED ───────────────────────────────────
# 使用以下命令生成：openssl rand -hex 64
# 长度至少 32 字符，生产环境推荐 64 字符以上
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_SECRET_openssl_rand_hex_64
JWT_REFRESH_EXPIRATION=7d

# ─── bcrypt ────────────────────────────────────────────────
# 生产环境最低 12，值越大越安全但登录越慢（推荐 12-14）
BCRYPT_SALT_ROUNDS=12

# ─── Redis ── REQUIRED ──────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# REQUIRED：必须设置 Redis 密码
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── Twilio（短信服务） ─────────────────────────────────────
# 生产环境必须配置，否则验证码功能不可用
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+8613800000000

# ─── 速率限制 ────────────────────────────────────────────────
# 全局：15 分钟内每个 IP 最多 100 次请求
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CORS ── REQUIRED ───────────────────────────────────────
# 填写前端域名，多个域名用逗号分隔
# 禁止使用通配符 *
CORS_ORIGIN=https://your-frontend-domain.com
