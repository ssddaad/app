# ============================================
# 开发环境 Dockerfile
# 
# 支持热重载，挂载源代码
# ============================================

FROM node:18-alpine

# 安装开发工具
RUN apk add --no-cache \
    git \
    curl \
    vim

# 设置工作目录
WORKDIR /app

# 复制依赖文件
COPY package*.json ./
COPY tsconfig.json ./

# 安装所有依赖（包括开发依赖）
RUN npm install

# 暴露端口
EXPOSE 3000

# 开发命令（使用 ts-node-dev 实现热重载）
CMD ["npm", "run", "dev"]
