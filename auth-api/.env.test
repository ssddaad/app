# 测试环境配置

# 服务器配置
PORT=3001
NODE_ENV=test

# 数据库配置
DATABASE_URL=postgresql://test:test@localhost:5432/test_auth_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test_auth_db
DB_USER=test
DB_PASSWORD=test

# JWT 配置
JWT_SECRET=test-jwt-secret-key-for-testing-only
JWT_EXPIRATION=1h
JWT_REFRESH_SECRET=test-refresh-secret-key
JWT_REFRESH_EXPIRATION=7d

# bcrypt 配置
BCRYPT_SALT_ROUNDS=10

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Twilio 配置（测试环境不使用）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS
CORS_ORIGIN=*
