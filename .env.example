# ============================================================
# 前端环境变量模板
# 使用方式：cp .env.example .env.local
# ============================================================

# 后端 Auth API 地址
# 开发环境（Vite proxy 会将 /api 转发到后端，此处留空即可）
# 生产环境填写后端完整域名，例：https://api.your-domain.com/api
VITE_API_BASE_URL=/api

# 硅基流动 AI API Key
# 获取地址：https://siliconflow.cn/
VITE_SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# AI 模型名称（可选，有默认值）
VITE_SILICONFLOW_MODEL=ft:LoRA/Qwen/Qwen2.5-7B-Instruct:d5rp7rmcnncc738k5sq0:breastcancer:oclicfelnbkxecoruzqr-ckpt_step_231
